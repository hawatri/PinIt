<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Dark variant of the picker theme — colors come from values-night/colors.xml,
         the parent flips to a dark Material theme so default text/widget tints
         match. -->
    <style name="Theme.PinIt.Picker" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/picker_bg</item>
        <item name="android:colorBackground">@color/picker_bg</item>
        <item name="android:textColorPrimary">@color/picker_text_primary</item>
        <item name="android:textColorSecondary">@color/picker_text_secondary</item>
    </style>

</resources>
